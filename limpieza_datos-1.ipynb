   "source": [
    "# Proyecto: Limpieza de Datos con POO\n",
    "**Encuesta socioeconómica — 50 registros**"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "2",
   "metadata": {},
   "source": [
    "## 1. Importar librerías"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "3",
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "4",
   "metadata": {},
   "source": [
    "## 2. Crear datos de ejemplo (encuesta con errores)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "5",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Dataset con 60 filas (50 válidos + errores/duplicados a propósito)\n",
    "datos = {\n",
    "    'nombre':   ['Ana','Luis','Maria','Carlos','Sofia','Pedro','Laura','Juan','Ana','Valeria',\n",
    "                 'Miguel','Lucia','Andres','Camila','Jorge','Natalia','Felipe','Diana','Oscar','Paula',\n",
    "                 'Ricardo','Elena','Sergio','Monica','Tomas','Isabel','Hector','Claudia','Raul','Adriana',\n",
    "                 'Fernando','Sandra','Gustavo','Marcela','Ernesto','Patricia','Rodrigo','Gloria','Jaime','Beatriz',\n",
    "                 'Cesar','Liliana','Alvaro','Esperanza','Ruben','Martha','Ignacio','Verónica','Pablo','Silvia',\n",
    "                 'Ana','Luis', None,'Carlos','ZZZ','Pedro','Laura',None,'Ana','Valeria'],\n",
    "\n",
    "    'edad':     [25,30,22,45,28,33,19,50,25,27,\n",
    "                 31,24,38,21,42,29,35,26,48,23,\n",
    "                 36,20,44,32,18,40,55,27,39,22,\n",
    "                 47,34,29,41,52,26,37,43,31,28,\n",
    "                 24,46,33,19,58,25,30,22,45,28,\n",
    "                 25,30,-5,45,999,'abc','Laura',None,25,27],\n",
    "\n",
    "    'genero':   ['F','M','f','m','Femenino','masculino','FEMENINO','M','F','f',\n",
    "                 'm','F','M','f','m','F','M','f','m','F',\n",
    "                 'M','f','m','F','M','f','m','F','M','f',\n",
    "                 'm','F','M','f','m','F','M','f','m','F',\n",
    "                 'M','f','m','F','M','f','m','F','M','f',\n",
    "                 'F','M','f','m','F','masculino','FEMENINO','M','F','f'],\n",
    "\n",
    "    'ciudad':   ['bogota','MEDELLÍN','Cali','bogotá','medellin','CALI','Bogota','Medellín','bogota','cali',\n",
    "                 'BOGOTA','medellin','Cali','bogota','MEDELLÍN','cali','Bogota','CALI','medellin','Bogota',\n",
    "                 'cali','BOGOTA','Medellín','cali','bogota','CALI','Bogota','medellin','CALI','Bogota',\n",
    "                 'medellin','BOGOTA','cali','Medellín','bogota','CALI','medellin','Bogota','cali','BOGOTA',\n",
    "                 'medellin','Bogota','CALI','bogota','Medellín','cali','BOGOTA','medellin','Bogota','cali',\n",
    "                 'bogota','MEDELLÍN','Cali','bogotá','medellin','CALI','Bogota','Medellín','bogota','cali'],\n",
    "\n",
    "    'ingreso':  [1500000,2000000,800000,3500000,1200000,4000000,900000,5000000,1500000,1100000,\n",
    "                 2500000,750000,3000000,850000,4500000,1300000,2200000,950000,6000000,1050000,\n",
    "                 2800000,780000,3200000,1150000,700000,3800000,7000000,1250000,2600000,820000,\n",
    "                 5500000,1400000,1900000,3600000,8000000,1000000,2400000,4200000,2100000,1350000,\n",
    "                 1700000,5200000,2300000,880000,9000000,1100000,1600000,830000,3400000,1200000,\n",
    "                 1500000,2000000,-100,3500000,'mucho',4000000,900000,None,1500000,1100000]\n",
    "}\n",
    "\n",
    "df = pd.DataFrame(datos)\n",
    "print('Filas originales:', len(df))\n",
    "df.head()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "6",
   "metadata": {},
   "source": [
    "## 3. Clase Limpiador"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "7",
   "metadata": {},
   "outputs": [],
   "source": [
    "class Limpiador:\n",
    "    \"\"\"\n",
    "    Clase para limpiar un DataFrame de encuesta socioeconómica.\n",
    "    \"\"\"\n",
    "\n",
    "    def __init__(self, df):\n",
    "        # Guardamos una copia para no modificar el original\n",
    "        self.df = df.copy()\n",
    "\n",
    "    # ── Método 1: normalizar ciudades ──────────────────────────────────────\n",
    "    def normalizar_ciudades(self):\n",
    "        \"\"\"\n",
    "        Pone todas las ciudades en minúsculas y sin tildes para unificar.\n",
    "        Ej: 'BOGOTÁ', 'bogota', 'Bogota' → 'bogota'\n",
    "        \"\"\"\n",
    "        reemplazos = {'á':'a','é':'e','í':'i','ó':'o','ú':'u','ñ':'n'}\n",
    "\n",
    "        def limpiar(texto):\n",
    "            if pd.isna(texto):\n",
    "                return texto\n",
    "            texto = str(texto).lower().strip()\n",
    "            for con_tilde, sin_tilde in reemplazos.items():\n",
    "                texto = texto.replace(con_tilde, sin_tilde)\n",
    "            return texto\n",
    "\n",
    "        self.df['ciudad'] = self.df['ciudad'].apply(limpiar)\n",
    "        return self  # permite encadenar métodos\n",
    "\n",
    "    # ── Método 2: estandarizar géneros ────────────────────────────────────\n",
    "    def estandarizar_generos(self):\n",
    "        \"\"\"\n",
    "        Convierte todas las variantes de género a 'M' o 'F'.\n",
    "        Ej: 'femenino', 'FEMENINO', 'f' → 'F'\n",
    "        \"\"\"\n",
    "        def limpiar(valor):\n",
    "            if pd.isna(valor):\n",
    "                return valor\n",
    "            valor = str(valor).lower().strip()\n",
    "            if valor in ['f', 'femenino']:\n",
    "                return 'F'\n",
    "            elif valor in ['m', 'masculino']:\n",
    "                return 'M'\n",
    "            else:\n",
    "                return None  # valor desconocido → lo marcamos como nulo\n",
    "\n",
    "        self.df['genero'] = self.df['genero'].apply(limpiar)\n",
    "        return self\n",
    "\n",
    "    # ── Método 3: convertir y validar ingresos ────────────────────────────\n",
    "    def limpiar_ingresos(self):\n",
    "        \"\"\"\n",
    "        Convierte ingresos a número.\n",
    "        Pone NaN si no es número o si es negativo.\n",
    "        \"\"\"\n",
    "        self.df['ingreso'] = pd.to_numeric(self.df['ingreso'], errors='coerce')\n",
    "        self.df.loc[self.df['ingreso'] < 0, 'ingreso'] = np.nan\n",
    "        return self\n",
    "\n",
    "    # ── Método 4: convertir y validar edades ──────────────────────────────\n",
    "    def limpiar_edades(self):\n",
    "        \"\"\"\n",
    "        Convierte edades a número.\n",
    "        Pone NaN si la edad es menor a 0 o mayor a 120.\n",
    "        \"\"\"\n",
    "        self.df['edad'] = pd.to_numeric(self.df['edad'], errors='coerce')\n",
    "        self.df.loc[(self.df['edad'] < 0) | (self.df['edad'] > 120), 'edad'] = np.nan\n",
    "        return self\n",
    "\n",
    "    # ── Método 5: eliminar duplicados e inválidos ─────────────────────────\n",
    "    def eliminar_invalidos(self):\n",
    "        \"\"\"\n",
    "        Elimina filas duplicadas y filas con valores nulos en columnas clave.\n",
    "        \"\"\"\n",
    "        antes = len(self.df)\n",
    "\n",
    "        # Quitar duplicados exactos\n",
    "        self.df = self.df.drop_duplicates()\n",
    "\n",
    "        # Quitar filas donde nombre, edad, genero o ingreso son nulos\n",
    "        self.df = self.df.dropna(subset=['nombre', 'edad', 'genero', 'ingreso'])\n",
    "\n",
    "        print(f'Filas eliminadas: {antes - len(self.df)}')\n",
    "        print(f'Filas limpias:    {len(self.df)}')\n",
    "        return self\n",
    "\n",
    "    # ── Método 6: resumen descriptivo ─────────────────────────────────────\n",
    "    def resumen(self):\n",
    "        \"\"\"\n",
    "        Muestra estadísticas básicas del dataset limpio.\n",
    "        \"\"\"\n",
    "        print('\\n====== RESUMEN DEL DATASET LIMPIO ======')\n",
    "        print(f'Total de registros: {len(self.df)}')\n",
    "        print(f'\\nEdad promedio:  {self.df[\"edad\"].mean():.1f} años')\n",
    "        print(f'Edad mínima:    {self.df[\"edad\"].min():.0f} años')\n",
    "        print(f'Edad máxima:    {self.df[\"edad\"].max():.0f} años')\n",
    "        print(f'\\nIngreso promedio: ${self.df[\"ingreso\"].mean():,.0f}')\n",
    "        print(f'Ingreso mínimo:   ${self.df[\"ingreso\"].min():,.0f}')\n",
    "        print(f'Ingreso máximo:   ${self.df[\"ingreso\"].max():,.0f}')\n",
    "        print(f'\\nDistribución por género:')\n",
    "        print(self.df['genero'].value_counts().to_string())\n",
    "        print(f'\\nDistribución por ciudad:')\n",
    "        print(self.df['ciudad'].value_counts().to_string())\n",
    "        return self\n",
    "\n",
    "    # ── Método extra: obtener el DataFrame limpio ─────────────────────────\n",
    "    def obtener_datos(self):\n",
    "        return self.df"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "8",
   "metadata": {},
   "source": [
    "## 4. Ejecutar la limpieza"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "9",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Crear el objeto y encadenar todos los métodos de limpieza\n",
    "limpiador = Limpiador(df)\n",
    "\n",
    "df_limpio = (\n",
    "    limpiador\n",
    "    .normalizar_ciudades()\n",
    "    .estandarizar_generos()\n",
    "    .limpiar_ingresos()\n",
    "    .limpiar_edades()\n",
    "    .eliminar_invalidos()\n",
    "    .resumen()\n",
    "    .obtener_datos()\n",
    ")\n",
    "\n",
    "df_limpio.head(10)"
   ]
  }
 ]
}"
